rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. 출석체크 (attendance) 규칙
    match /attendance/{attendanceId} {
      // 누구나 다른 사람의 출석 여부를 조회할 수 있습니다.
      allow read: if true;
      
      // 로그인된 사용자만 자신의 출석 정보를 추가, 변경, 삭제할 수 있습니다.
      // 문서 ID 포맷: '유저UID_날짜'
      allow create, update: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    
    // 2. 오늘의 한마디 (social_messages) 규칙
    match /social_messages/{messageId} {
      // 누구나 멤버들의 한마디를 읽을 수 있습니다.
      allow read: if true;
      
      // 로그인된 사용자만 메시지를 올릴 수 있습니다.
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      
      // 본인이 작성한 메시지만 삭제할 수 있습니다.
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
      
      // 메시지 수정은 차단합니다.
      allow update: if false;
    }
  }
}
