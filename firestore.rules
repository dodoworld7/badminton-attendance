rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. 출석체크 (attendance) 규칙
    match /attendance/{attendanceId} {
      allow read: if true;
      
      // 로그인된 사용자만 자신의 출석 정보를 추가, 변경, 삭제할 수 있습니다.
      // 최고 관리자(admin@admin.com)는 제한 없이 생성, 수정, 삭제가 가능합니다.
      allow create, update: if request.auth != null && (request.resource.data.user_id == request.auth.uid || request.auth.token.email == 'admin@admin.com');
      allow delete: if request.auth != null && (resource.data.user_id == request.auth.uid || request.auth.token.email == 'admin@admin.com');
    }
    
    // 2. 오늘의 한마디 (social_messages) 규칙
    match /social_messages/{messageId} {
      allow read: if true;
      
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      
      // 본인이 작성했거나 관리자인 경우 삭제 가능
      allow delete: if request.auth != null && (resource.data.user_id == request.auth.uid || request.auth.token.email == 'admin@admin.com');
      
      allow update: if false;
    }

    // 3. 사용자 정보 (users) 규칙
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'admin@admin.com');
    }
  }
}
